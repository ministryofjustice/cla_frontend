#!/bin/sh -e
NAMESPACE=$1
DYNAMIC_HOSTNAME=$2

# These variables are required in multiple places such as
# the bin/<NAMESPACE>_deploy.sh scripts

# IMAGE_TAG matches the format used by GitHub Actions (branch-<sha> / main-<sha>)
# so that the behave job can find images built and pushed by GHA.
# This is temporary — once behave is migrated to GHA (blocked on
# ministryofjustice/cla-end-to-end-tests being migrated), this file
# and the behave job can be removed from CircleCI entirely.
if [ "$CIRCLE_BRANCH" = "main" ]; then
  export IMAGE_TAG="main-$CIRCLE_SHA1"
else
  export IMAGE_TAG="branch-$CIRCLE_SHA1"
fi

export CLEANED_BRANCH_NAME=$(echo $CIRCLE_BRANCH | sed 's/^feature[-/]//' | sed 's:^\w*\/::' | tr -s ' _/[]().' '-' | tr '[:upper:]' '[:lower:]' | cut -c1-28 | sed 's/-$//')
if [ $DYNAMIC_HOSTNAME = true ]; then
  export RELEASE_NAME=${CLEANED_BRANCH_NAME}
  export RELEASE_HOST=${RELEASE_NAME}-${HOST}
else
  export RELEASE_NAME=cla-frontend
  export RELEASE_HOST=${HOST}
fi

